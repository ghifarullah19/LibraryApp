						"body": {
							"mode": "raw",
							"raw": "{\n    \"title\": \"Tutorial Laravel 11 (Edisi Revisi)\",\n    \"author_id\": 1,\n    \"publisher_id\": 1,\n    \"publish_year\": 2025\n}",
							"options": {"raw": {"language": "json"}}
						},
						"url": {"raw": "{{base_url}}/books/1", "host": ["{{base_url}}"], "path": ["books", "1"]}
					}
				},
