						"method": "GET",
						"header": [{"key": "Accept", "value": "application/json"}],
						"url": {"raw": "{{base_url}}/books?page=1&limit=10&search=&sort_by=created_at&sort_order=desc", "host": ["{{base_url}}"], "path": ["books"], "query": [{"key": "page", "value": "1"}, {"key": "limit", "value": "10"}, {"key": "search", "value": ""}, {"key": "sort_by", "value": "created_at"}, {"key": "sort_order", "value": "desc"}]}
