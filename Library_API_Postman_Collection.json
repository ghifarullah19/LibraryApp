						"body": {
							"mode": "raw",
							"raw": "{\n    \"title\": \"Tutorial Laravel 11\",\n    \"description\": \"Buku panduan lengkap membuat API\",\n    \"author_id\": 1,\n    \"publisher_id\": 1,\n    \"publish_year\": 2024\n}",
